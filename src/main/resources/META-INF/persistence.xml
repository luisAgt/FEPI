<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
  <!-- Define Persistence Unit -->
  <persistence-unit name="AccescomPU" transaction-type="RESOURCE_LOCAL">
    <provider>
          org.hibernate.jpa.HibernatePersistenceProvider
      </provider>
    <class>com.equipo1.entities.Book</class>
    <class>com.equipo1.entities.Schedule</class>
    <class>com.equipo1.entities.Horary</class>
    <class>com.equipo1.entities.Enrollment</class>
    <class>com.equipo1.entities.Professor</class>
    <class>com.equipo1.entities.Classroom</class>
    <class>com.equipo1.entities.Subject</class>
    <class>com.equipo1.entities.Attendance</class>
    <class>com.equipo1.entities.Student</class>
    <class>com.equipo1.entities.Users</class>
    <class>com.equipo1.entities.LoanBook</class>
    <class>com.equipo1.entities.LabMaterial</class>
    <class>com.equipo1.entities.LoanMaterial</class>
    <class>com.equipo1.entities.AccessSchool</class>
    <class>com.equipo1.entities.AcademicGroup</class>
    <properties>
      <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/Accescom?serverTimezone=UTC"/>
      <property name="javax.persistence.jdbc.user" value="root"/>
      <property name="javax.persistence.jdbc.password" value="luisagt"/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
